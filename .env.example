# OpenModel — Docker Environment Variables
# Copy to .env and fill in actual values: cp .env.example .env

# Config file selection (filename under config/ directory)
# Options: sidecar-prod-test.yaml, sidecar-8gpu-multi.yaml, sidecar-8gpu-tensor.yaml, sidecar-foc.yaml
SIDECAR_CONFIG=sidecar-8gpu-multi.yaml

# Lotus daemon
LOTUS_API_TOKEN=eyJ...

# HuggingFace
HF_ENDPOINT=https://huggingface.co
HF_TOKEN=
HF_CACHE_DIR=~/.cache/huggingface

# Model cache directory (shared by inference and foc-bridge)
MODEL_CACHE_DIR=~/openmodel/models

# FOC Bridge（Filecoin Orbit Chain）
FOC_PRIVATE_KEY=
FOC_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
FOC_BRIDGE_PORT=3100
SP_URL_PRIMARY=https://caliberation-pdp.infrafolio.com/piece
SP_URL_SECONDARY=https://calib2.ezpdpz.net/piece
